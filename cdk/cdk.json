{
  "app": "npx ts-node -P tsconfig.json --prefer-ts-exts src/main.ts",
  "output": "cdk.out",
  "context": {
    "blueprintRepo": "krokoko/agent-plugins"
  },
  "build": "node -e \"process.exit(0)\"",
  "watch": {
    "include": ["src/**/*.ts", "test/**/*.ts"],
    "exclude": [
      "README.md",
      "cdk*.json",
      "**/*.d.ts",
      "**/*.js",
      "tsconfig.json",
      "package*.json",
      "yarn.lock",
      "node_modules"
    ]
  }
}
