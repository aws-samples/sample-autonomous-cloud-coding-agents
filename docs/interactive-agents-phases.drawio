        <mxCell id="p8-n1" parent="p8-1" style="shape=note;size=14;fillColor=#FFF9C4;strokeColor=#F9A825;html=1;fontSize=11;fontFamily=Helvetica;align=left;verticalAlign=top;spacing=8;whiteSpace=wrap;" value="&lt;b&gt;Phase 1b gap in design Appendix C:&lt;/b&gt; getTaskEvents Lambda currently supports only next_token (base64 LastEvaluatedKey), not ?after=&amp;lt;event_id&amp;gt;. Must be modified to accept ULID after-cursor and translate to SK &gt; cursor Query. This is the smallest API change needed to unblock reconnect catch-up." vertex="1">
          <mxGeometry height="120" width="900" x="60" y="1010" as="geometry" />
        </mxCell>
        <mxCell id="p8-n2" parent="p8-1" style="shape=note;size=14;fillColor=#C8E6C9;strokeColor=#2E7D32;html=1;fontSize=11;fontFamily=Helvetica;fontColor=#2E7D32;align=left;verticalAlign=top;spacing=8;whiteSpace=wrap;" value="&lt;b&gt;Why DDB is the catch-up source:&lt;/b&gt; ProgressWriter writes every AG-UI event to TaskEventsTable with a ULID event_id (lexicographically ordered). A client can always resume from any point by querying SK &gt; lastEventId. SSE holds only live tail." vertex="1">
          <mxGeometry height="120" width="870" x="990" y="1010" as="geometry" />
        </mxCell>
        <mxCell id="p8-n3" parent="p8-1" style="shape=note;size=14;fillColor=#FFCDD2;strokeColor=#C62828;html=1;fontSize=11;fontFamily=Helvetica;fontColor=#C62828;align=left;verticalAlign=top;spacing=8;" value="&lt;b&gt;Streaming cap:&lt;/b&gt; AgentCore caps streaming at 60 minutes. Tasks exceeding this require a fresh reconnect. CLI must gracefully handle the 60-min close and re-issue the catch-up query to continue." vertex="1">
          <mxGeometry height="80" width="1800" x="60" y="1150" as="geometry" />
        </mxCell>
      </root>
