        <mxCell id="p7-bInfo" parent="p7-bBox" style="rounded=1;fillColor=#FFFFFF;strokeColor=#2E7D32;html=1;align=center;verticalAlign=top;fontSize=14;fontFamily=Helvetica;fontColor=#2E7D32;spacing=8;whiteSpace=wrap;" value="&lt;b&gt;Trade-offs&lt;/b&gt;&lt;br&gt;+ eventsource-parser ~26M weekly dl, maintained&lt;br&gt;+ Full control: reconnect, backoff, JWT refresh, cancel&lt;br&gt;+ Smallest dep tree for the CLI&lt;br&gt;+ Node 20+ native fetch — no polyfill&lt;br&gt;- Must hand-write event → CLI renderer mapping&lt;br&gt;- Must implement typed AG-UI schemas ourselves&lt;br&gt;&lt;br&gt;&lt;b&gt;Best fit for a terminal client where&lt;/b&gt;&lt;br&gt;&lt;b&gt;reconnect UX and JWT refresh matter.&lt;/b&gt;" vertex="1">
