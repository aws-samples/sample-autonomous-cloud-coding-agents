        <mxCell id="p8-m15" edge="1" parent="p8-1" style="endArrow=classic;dashed=1;html=1;fontSize=10;fontFamily=Helvetica;fontColor=#C62828;labelBackgroundColor=#FFFFFF;" value="⏱ 60-min hard cap → server closes">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="880" y="930" as="sourcePoint" />
            <mxPoint x="130" y="930" as="targetPoint" />
