        <mxCell id="p3-bidi" parent="p3-1" style="rounded=1;fillColor=light-dark(#FFFFFF,#2a2a2a);strokeColor=#ED7100;strokeWidth=3;strokeDasharray=10 5;html=1;verticalAlign=top;fontStyle=1;fontSize=16;fontFamily=Helvetica;fontColor=#BF5700;container=1;collapsible=0;spacingLeft=10;spacingTop=6;" value="FUTURE: BIDIRECTIONAL PLANE (WebSocket /ws, Phase 1c+) — NOT YET BUILT" vertex="1">
          <mxGeometry height="240" width="1800" x="40" y="940" as="geometry" />
        </mxCell>
        <mxCell id="p3-bidi-d" parent="p3-bidi" style="text;html=1;fontSize=12;fontFamily=Helvetica;fontColor=#BF5700;align=left;verticalAlign=top;spacing=8;" value="&lt;b&gt;Transport:&lt;/b&gt; WebSocket /ws (client↔server).&amp;nbsp;&lt;div&gt;&lt;b&gt;Use case:&lt;/b&gt; &lt;b&gt;synchronous&lt;/b&gt; tool-call approvals + HITL acknowledgment within &lt;100ms.&amp;nbsp;&lt;/div&gt;&lt;div&gt;&lt;b&gt;Payload:&lt;/b&gt; server→client identical to SSE (17 AG-UI events), client→server adds TOOL_USE_APPROVAL_RESPONSE, CANCEL.&amp;nbsp;&lt;/div&gt;&lt;div&gt;&lt;b&gt;Status:&lt;/b&gt; Phase 1c+, optional. &lt;b&gt;Asynchronous nudges and approvals do NOT need this&lt;/b&gt; — those use REST (Phase 2, see page 8).&lt;/div&gt;" vertex="1">
          <mxGeometry height="90" width="1760" x="20" y="40" as="geometry" />
        </mxCell>
        <mxCell id="p3-bidi-cli" parent="p3-bidi" style="rounded=1;fillColor=light-dark(#FFFFFF,#2a2a2a);strokeColor=#ED7100;strokeDasharray=6 3;html=1;align=center;verticalAlign=middle;fontSize=11;fontStyle=1;fontFamily=Helvetica;fontColor=#BF5700;" value="CLI / Web (bidirectional)" vertex="1">
          <mxGeometry height="60" width="220" x="30" y="150" as="geometry" />
        </mxCell>
        <mxCell id="p3-bidi-rt" parent="p3-bidi" style="rounded=1;fillColor=light-dark(#FFFFFF,#2a2a2a);strokeColor=#ED7100;strokeDasharray=6 3;html=1;align=center;verticalAlign=middle;fontSize=11;fontStyle=1;fontFamily=Helvetica;fontColor=#BF5700;" value="Runtime-JWT /ws" vertex="1">
          <mxGeometry height="60" width="220" x="1230" y="150" as="geometry" />
        </mxCell>
        <mxCell id="p3-bidi-e" edge="1" parent="p3-bidi" source="p3-bidi-cli" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;fontFamily=Helvetica;strokeColor=#ED7100;strokeDasharray=6 3;startArrow=classic;endArrow=classic;" target="p3-bidi-rt">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="p3-bidi-el" connectable="0" parent="p3-bidi-e" style="edgeLabel;html=1;fontSize=11;fontFamily=Helvetica;fontColor=#BF5700;fontStyle=1;" value="sync approvals ⇄ events" vertex="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="p3-summary" parent="p3-1" style="rounded=1;fillColor=#FFECB3;strokeColor=#F9A825;html=1;align=left;verticalAlign=top;fontSize=12;fontFamily=Helvetica;fontColor=#BF5700;spacing=10;whiteSpace=wrap;fontStyle=1;" value="Key insight: the REST control plane is permanent. It is NOT replaced by streaming. Every task lifecycle event ultimately touches it (submit, status, catch-up, cancel). SSE and fan-out are orthogonal additions on top." vertex="1">
          <mxGeometry height="60" width="1800" x="40" y="1200" as="geometry" />
        </mxCell>
