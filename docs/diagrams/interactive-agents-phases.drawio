        <mxCell id="p3-ctrl-e7" edge="1" parent="p3-ctrl" source="p3-ctrl-agent" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;fontFamily=Helvetica;strokeColor=#8C4FFF;" target="p3-ctrl-api">
