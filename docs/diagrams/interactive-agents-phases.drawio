        <mxCell id="p5-p2-m8" edge="1" parent="p5-1" style="endArrow=classic;html=1;fontSize=10;fontFamily=Helvetica;labelBackgroundColor=#FFFFFF;fontStyle=1;" value="8. RUN_FINISHED → PutItem (status=COMPLETED, pr_url)">
          <mxGeometry relative="1" x="0.0111" y="15" as="geometry">
