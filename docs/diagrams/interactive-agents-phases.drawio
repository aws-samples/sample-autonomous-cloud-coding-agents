        <mxCell id="p6-B3a" edge="1" parent="p6-1" style="endArrow=classic;html=1;fontSize=10;fontFamily=Helvetica;labelBackgroundColor=#FFFFFF;strokeColor=#8C4FFF;strokeWidth=2;" value="B3a. GET /tasks/{id}/events?after=01J123...A (catch-up)">
          <mxGeometry relative="1" x="-0.0054" y="-15" as="geometry">
