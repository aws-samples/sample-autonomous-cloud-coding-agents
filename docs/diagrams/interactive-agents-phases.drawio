        </mxCell>
        <mxCell id="p3-stream" parent="p3-1" style="rounded=1;fillColor=#C8E6C9;strokeColor=#2E7D32;strokeWidth=3;html=1;verticalAlign=top;fontStyle=1;fontSize=16;fontFamily=Helvetica;fontColor=#2E7D32;container=1;collapsible=0;spacingLeft=10;spacingTop=6;" value="STREAMING PLANE (SSE, interactive only) — NEW in Phase 1b" vertex="1">
          <mxGeometry height="240" width="1800" x="40" y="420" as="geometry" />
        </mxCell>
        <mxCell id="p3-stream-d" parent="p3-stream" style="text;html=1;fontSize=12;fontFamily=Helvetica;fontColor=#2E7D32;align=left;verticalAlign=top;spacing=8;" value="&lt;b&gt;Transport:&lt;/b&gt; HTTPS SSE, direct CLI/Web → Runtime-JWT (bypasses orchestrator, bypasses API Gateway REST).&amp;nbsp;&lt;div&gt;&lt;b&gt;Wire format:&lt;/b&gt; 17 AG-UI event types. &lt;b&gt;Auth:&lt;/b&gt; Cognito JWT bearer validated by AgentCore customJWTAuthorizer.&amp;nbsp;&lt;/div&gt;&lt;div&gt;&lt;b&gt;Constraint:&lt;/b&gt; 60-min streaming cap (non-adjustable AWS quota). Reconnect uses same runtimeSessionId + REST /events?after=id catch-up.&lt;/div&gt;" vertex="1">
          <mxGeometry height="80" width="1760" x="20" y="40" as="geometry" />
        </mxCell>
        <mxCell id="p3-stream-cli" parent="p3-stream" style="rounded=1;fillColor=#E8F5E9;strokeColor=#2E7D32;html=1;align=center;verticalAlign=middle;fontSize=11;fontStyle=1;fontFamily=Helvetica;fontColor=#2E7D32;strokeWidth=2;" value="CLI (live watch)" vertex="1">
          <mxGeometry height="60" width="160" x="30" y="150" as="geometry" />
        </mxCell>
