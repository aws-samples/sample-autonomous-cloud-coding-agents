        <mxCell id="p6-B2" edge="1" parent="p6-1" style="endArrow=classic;html=1;fontSize=10;fontFamily=Helvetica;labelBackgroundColor=#FFFFFF;fontStyle=1;edgeStyle=orthogonalEdgeStyle;entryX=0.037;entryY=0.452;entryDx=0;entryDy=0;entryPerimeter=0;" target="p6-phaseB" value="B2. CLI detects close; reads cached last_event_id=01J123...A; begins PARALLEL fetch">
          <mxGeometry relative="1" x="-0.0037" y="213" as="geometry">
