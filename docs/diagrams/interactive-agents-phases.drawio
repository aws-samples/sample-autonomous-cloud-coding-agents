        <mxCell id="p4-r5c5" parent="p4-1" style="rounded=0;fillColor=light-dark(#FFFFFF,#2a2a2a);strokeColor=#666666;html=1;align=left;verticalAlign=middle;fontSize=11;fontFamily=Helvetica;spacingLeft=10;" value="long-running agent → email summary on completion or failure" vertex="1">
