  <diagram name="2. Control vs streaming vs fan-out planes" id="v5p2">
    <mxGraphModel dx="1543" dy="1105" grid="0" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="0" pageScale="1" pageWidth="1900" pageHeight="1400" math="0" shadow="0">
      <root>
        <mxCell id="p3-0" />
        <mxCell id="p3-1" parent="p3-0" />
        <mxCell id="p3-t" parent="p3-1" style="text;html=1;align=left;verticalAlign=top;fontSize=26;fontStyle=1;fontFamily=Helvetica;" value="Four orthogonal planes — every channel uses control; streaming is additive" vertex="1">
          <mxGeometry height="40" width="1800" x="40" y="20" as="geometry" />
        </mxCell>
        <mxCell id="p3-ts" parent="p3-1" style="text;html=1;align=left;verticalAlign=top;fontSize=13;fontFamily=Helvetica;fontColor=#555555;" value="Submission (REST) is universal. Consumption uses streaming plane (interactive SSE), fan-out plane (async push to non-interactive consumers), or future bidirectional plane (WebSocket nudges). Planes are orthogonal — a single task may use 1+." vertex="1">
          <mxGeometry height="50" width="1800" x="40" y="60" as="geometry" />
        </mxCell>
        <mxCell id="p3-bar" parent="p3-1" style="line;strokeWidth=2;strokeColor=#666666;html=1;" value="" vertex="1">
          <mxGeometry height="10" width="1800" x="40" y="115" as="geometry" />
        </mxCell>
        <mxCell id="p3-ctrl" parent="p3-1" style="rounded=1;fillColor=#EDE7F6;strokeColor=#8C4FFF;strokeWidth=3;html=1;verticalAlign=top;fontStyle=1;fontSize=16;fontFamily=Helvetica;fontColor=#8C4FFF;container=1;collapsible=0;spacingLeft=10;spacingTop=6;" value="CONTROL PLANE (REST, always) — used by ALL channels" vertex="1">
          <mxGeometry height="250" width="1800" x="40" y="150" as="geometry" />
        </mxCell>
        <mxCell id="p3-ctrl-d" parent="p3-ctrl" style="text;html=1;fontSize=12;fontFamily=Helvetica;fontColor=#8C4FFF;align=left;verticalAlign=top;spacing=8;" value="&lt;b&gt;Transport:&lt;/b&gt; HTTPS REST through API Gateway. &lt;b&gt;Endpoints:&lt;/b&gt; POST /tasks (submit), GET /tasks/{id} (status), GET /tasks/{id}/events?after=id (catch-up), DELETE /tasks/{id} (cancel), admin CRUD.&amp;nbsp;&lt;div&gt;&lt;b&gt;Guarantee:&lt;/b&gt; durable, idempotent, bounded latency (&amp;lt;1s). &lt;b&gt;Auth:&lt;/b&gt; Cognito JWT bearer.&lt;/div&gt;" vertex="1">
          <mxGeometry height="70" width="1760" x="20" y="40" as="geometry" />
        </mxCell>
        <mxCell id="p3-ctrl-cli" parent="p3-ctrl" style="rounded=1;fillColor=light-dark(#FFFFFF,#2a2a2a);strokeColor=#8C4FFF;html=1;align=center;verticalAlign=middle;fontSize=11;fontStyle=1;fontFamily=Helvetica;fontColor=#8C4FFF;" value="CLI" vertex="1">
