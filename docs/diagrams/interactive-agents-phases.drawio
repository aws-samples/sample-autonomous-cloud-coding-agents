        <mxCell id="p6-B7" edge="1" parent="p6-1" style="endArrow=classic;html=1;fontSize=10;fontFamily=Helvetica;labelBackgroundColor=#FFFFFF;strokeColor=#2E7D32;strokeWidth=2;" value="B3b (parallel). SSE reconnect (same runtimeSessionId, exp backoff)">
