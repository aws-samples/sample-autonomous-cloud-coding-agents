        <mxCell id="p4-r5c3" parent="p4-1" style="rounded=0;fillColor=light-dark(#FFFFFF,#2a2a2a);strokeColor=#666666;html=1;align=left;verticalAlign=middle;fontSize=11;fontColor=#C925D1;fontFamily=Helvetica;spacingLeft=10;fontStyle=1;" value="push (digest)" vertex="1">
