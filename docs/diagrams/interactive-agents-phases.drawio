        </mxCell>
        <mxCell id="p4-r5c4" parent="p4-1" style="rounded=0;fillColor=light-dark(#FFFFFF,#2a2a2a);strokeColor=#666666;html=1;align=left;verticalAlign=middle;fontSize=11;fontColor=#C925D1;fontFamily=Helvetica;spacingLeft=10;" value="DDB Stream fan-out&#xa;→ SES / SNS" vertex="1">
          <mxGeometry height="80" width="280" x="760" y="520" as="geometry" />
