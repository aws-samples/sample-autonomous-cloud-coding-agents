        <mxCell id="p5note1" parent="1" style="rounded=1;fillColor=light-dark(#FFFDE7,#2a2a14);strokeColor=#F9A825;strokeWidth=2;html=1;align=left;verticalAlign=top;fontSize=10;fontFamily=Helvetica;fontColor=light-dark(#6B4E00,#FFD180);spacing=8;whiteSpace=wrap;fontStyle=1;" value="OrchestratorFn streams-but-discards: Lambda consumes events, logs them to CloudWatch, but the durable record is ProgressWriter → TaskEventsTable. After 15 min, Lambda must exit — but the agent&#39;s sync background thread in the microVM keeps running (up to 8h)." vertex="1">
