        <mxCell id="p6-B-cap" parent="p6-1" style="rounded=1;fillColor=#FFECB3;strokeColor=#F9A825;html=1;align=left;fontSize=10;fontFamily=Helvetica;fontColor=#BF5700;spacing=8;fontStyle=1;whiteSpace=wrap;" value="Trigger examples: wifi flakes out · AgentCore 60-min cap · idleRuntimeSessionTimeout exhausted · proxy restart · CLI laptop sleeps" vertex="1">
