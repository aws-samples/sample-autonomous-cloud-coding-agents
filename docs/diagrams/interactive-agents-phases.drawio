        <mxCell id="p5-m-guard" parent="p5-1" style="rounded=1;fillColor=light-dark(#FFFDE7,#2a2a14);strokeColor=#F9A825;strokeWidth=2;html=1;align=left;fontSize=9;fontFamily=Helvetica;fontColor=light-dark(#BF5700,#FFD180);spacing=4;fontStyle=1;whiteSpace=wrap;" value="5a. RUN_ELSEWHERE guard: server.py reads TaskTable by task_id;&amp;nbsp;&lt;div&gt;if execution_mode ≠ &#39;interactive&#39; → 409 {code:RUN_ELSEWHERE}. Else hydrate params from TaskTable, then attach-don&#39;t-spawn via {task_id: adapter} registry.&lt;/div&gt;" vertex="1">
          <mxGeometry height="36" width="1900" x="170" y="538" as="geometry" />
        </mxCell>
