        <mxCell id="p6-t" parent="p6-1" style="text;html=1;align=left;verticalAlign=top;fontSize=26;fontStyle=1;fontFamily=Helvetica;fontColor=#ED7100;" value="Phase 1b — reconnection flow (network blip or 60-min cap)" vertex="1">
          <mxGeometry height="40" width="1900" x="40" y="20" as="geometry" />
