        <mxCell id="p5-n1" parent="p5-1" style="shape=note;size=14;fillColor=#E3F2FD;strokeColor=#1F6FEB;html=1;fontSize=10;fontFamily=Helvetica;fontColor=#1F6FEB;align=left;verticalAlign=top;spacing=8;whiteSpace=wrap;" value="&lt;b&gt;ProgressWriter = durability&lt;/b&gt;&lt;br&gt;Every event lands in DDB TaskEventsTable. Survives microVM crash, SSE disconnect, Lambda restart. DDB Stream feeds the fan-out plane. getTaskEvents Lambda serves catch-up queries." vertex="1">
          <mxGeometry height="110" width="700" x="40" y="1450" as="geometry" />
        </mxCell>
        <mxCell id="p5-n2" parent="p5-1" style="shape=note;size=14;fillColor=#C8E6C9;strokeColor=#2E7D32;html=1;fontSize=10;fontFamily=Helvetica;fontColor=#2E7D32;align=left;verticalAlign=top;spacing=8;whiteSpace=wrap;" value="&lt;b&gt;SSEAdapter = real-time delivery&lt;/b&gt;&lt;br&gt;Pushes identical payload into per-session asyncio.Queue. Server drains Queue and emits SSE. If no client connected, push is no-op. Zero coupling between persistence and delivery." vertex="1">
          <mxGeometry height="110" width="700" x="760" y="1450" as="geometry" />
        </mxCell>
        <mxCell id="p5-n3" parent="p5-1" style="shape=note;size=14;fillColor=#FFECB3;strokeColor=#F9A825;html=1;fontSize=10;fontFamily=Helvetica;fontColor=#BF5700;align=left;verticalAlign=top;spacing=8;whiteSpace=wrap;" value="&lt;b&gt;Why dual emission?&lt;/b&gt;&lt;br&gt;Independent failure modes: DDB throttle does not stop SSE delivery; client disconnect does not drop DDB write. Each path is fail-open — agent keeps running even if both fail." vertex="1">
          <mxGeometry height="110" width="700" x="1480" y="1450" as="geometry" />
        </mxCell>
