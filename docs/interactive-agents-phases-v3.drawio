        <mxCell id="p6-C1" edge="1" parent="p6-1" style="endArrow=classic;html=1;fontSize=10;fontFamily=Helvetica;labelBackgroundColor=#FFFFFF;strokeColor=#1F6FEB;" value="C1. new milestone → PutItem (event_id=01J123...C)">
