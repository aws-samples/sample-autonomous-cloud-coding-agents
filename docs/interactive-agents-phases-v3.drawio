        <mxCell id="p2-api-i" parent="p2-api" style="shape=mxgraph.aws4.resourceIcon;resIcon=mxgraph.aws4.api_gateway;fillColor=#8C4FFF;strokeColor=#ffffff;aspect=fixed;html=1;verticalLabelPosition=bottom;verticalAlign=top;align=center;fontSize=10;fontFamily=Helvetica;" value="API Gateway" vertex="1">
