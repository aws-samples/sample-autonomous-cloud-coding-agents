        </mxCell>
        <mxCell id="p4-r7c3" parent="p4-1" style="rounded=0;fillColor=light-dark(#FFFFFF,#2a2a2a);strokeColor=#666666;html=1;align=left;verticalAlign=middle;fontSize=11;fontColor=#8C4FFF;fontFamily=Helvetica;spacingLeft=10;fontStyle=1;" value="poll or push (depends)" vertex="1">
          <mxGeometry height="80" width="250" x="510" y="680" as="geometry" />
        </mxCell>
        <mxCell id="p4-r7c4" parent="p4-1" style="rounded=0;fillColor=light-dark(#FFFFFF,#2a2a2a);strokeColor=#666666;html=1;align=left;verticalAlign=middle;fontSize=11;fontColor=#8C4FFF;fontFamily=Helvetica;spacingLeft=10;" value="REST GET or&#xa;DDB Stream fan-out" vertex="1">
          <mxGeometry height="80" width="280" x="760" y="680" as="geometry" />
        </mxCell>
        <mxCell id="p4-r7c5" parent="p4-1" style="rounded=0;fillColor=light-dark(#FFFFFF,#2a2a2a);strokeColor=#666666;html=1;align=left;verticalAlign=middle;fontSize=11;fontFamily=Helvetica;spacingLeft=10;" value="planner agent delegates sub-task to coder agent; callback webhook on completion" vertex="1">
          <mxGeometry height="80" width="760" x="1040" y="680" as="geometry" />
        </mxCell>
        <mxCell id="p4-callout" parent="p4-1" style="rounded=1;fillColor=#FFECB3;strokeColor=#F9A825;html=1;align=left;verticalAlign=top;fontSize=12;fontFamily=Helvetica;fontColor=#BF5700;spacing=10;whiteSpace=wrap;fontStyle=1;" value="Slack bots MUST ack in 3 seconds — submission (REST POST /tasks) can never hold open a stream.&#xa;&lt;span style=&#39;font-weight:normal;font-size:11px&#39;&gt;This is why Slack, GitHub, and other chat-style channels use fan-out PUSH instead of SSE. The submission path ACKs immediately; progress notifications arrive later via DDB Stream → Lambda → chat.postMessage.&lt;/span&gt;" vertex="1">
          <mxGeometry height="95" width="1800" x="40" y="800" as="geometry" />
        </mxCell>
        <mxCell id="p4-sub1" parent="p4-1" style="rounded=1;fillColor=#C8E6C9;strokeColor=#2E7D32;html=1;align=left;verticalAlign=top;fontSize=11;fontFamily=Helvetica;fontColor=#2E7D32;spacing=10;whiteSpace=wrap;fontStyle=1;" value="Green rows = interactive (SSE)&#xa;&lt;span style=&#39;font-weight:normal&#39;&gt;CLI and Web SPA. Long-lived connection; human watching live.&lt;/span&gt;" vertex="1">
          <mxGeometry height="70" width="580" x="40" y="910" as="geometry" />
        </mxCell>
        <mxCell id="p4-sub2" parent="p4-1" style="rounded=1;fillColor=#F5E6F7;strokeColor=#C925D1;html=1;align=left;verticalAlign=top;fontSize=11;fontFamily=Helvetica;fontColor=#C925D1;spacing=10;whiteSpace=wrap;fontStyle=1;" value="Magenta rows = async push (DDB Stream)&#xa;&lt;span style=&#39;font-weight:normal&#39;&gt;Slack, GitHub, Email/SMS. Fan-out Lambda delivers to external API.&lt;/span&gt;" vertex="1">
          <mxGeometry height="70" width="580" x="640" y="910" as="geometry" />
        </mxCell>
        <mxCell id="p4-sub3" parent="p4-1" style="rounded=1;fillColor=#EDE7F6;strokeColor=#8C4FFF;html=1;align=left;verticalAlign=top;fontSize=11;fontFamily=Helvetica;fontColor=#8C4FFF;spacing=10;whiteSpace=wrap;fontStyle=1;" value="Purple rows = poll (REST)&#xa;&lt;span style=&#39;font-weight:normal&#39;&gt;Cron/CI, Agent-to-agent. No live watcher; check status on a schedule.&lt;/span&gt;" vertex="1">
          <mxGeometry height="70" width="580" x="1240" y="910" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
  <diagram name="5. Phase 1b happy-path flow" id="p5-page">
    <mxGraphModel dx="1880" dy="953" grid="0" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="0" pageScale="1" pageWidth="2400" pageHeight="2500" math="0" shadow="0">
      <root>
        <mxCell id="p5-0" />
        <mxCell id="p5-1" parent="p5-0" />
        <mxCell id="p5-t" parent="p5-1" style="text;html=1;align=left;verticalAlign=top;fontSize=26;fontStyle=1;fontFamily=Helvetica;fontColor=#2E7D32;" value="Phase 1b rev-5 — happy paths (Path 1: interactive · Path 2: orchestrator + watch)" vertex="1">
          <mxGeometry height="40" width="2200" x="40" y="20" as="geometry" />
        </mxCell>
        <mxCell id="p5-ts" parent="p5-1" style="text;html=1;align=left;verticalAlign=top;fontSize=13;fontFamily=Helvetica;fontColor=#555555;" value="Path 1 (top, `bgagent run` / `submit --watch`): REST admits with execution_mode=interactive → Lambda writes TaskTable + task_created event, SKIPS orchestrator. CLI opens SSE direct to Runtime-JWT. server.py runs RUN_ELSEWHERE guard (reads TaskTable.execution_mode — must be &#39;interactive&#39; or → 409). Then hydrates params from TaskTable and spawns pipeline SAME-PROCESS. Every event: ProgressWriter → DDB (durable) + _SSEAdapter → observer Queue → SSE (real-time). Reconnect within same microVM → attach existing adapter.&#xa;&#xa;Path 2 (bottom, plain `bgagent submit` + `bgagent watch --transport auto`): REST admits with execution_mode=orchestrator (default) → Lambda async-invokes OrchestratorFn → Runtime-IAM (SigV4, Accept: json, sync spawn). CLI `watch` reads snapshot, checks execution_mode client-side: if ≠ &#39;interactive&#39;, skips SSE attempt entirely and polls GET /tasks/{id}/events?after= (no 424 reconnect storm). Server-side 409 stays as defence-in-depth." vertex="1">
          <mxGeometry height="50" width="2200" x="40" y="60" as="geometry" />
        </mxCell>
        <mxCell id="p5-bar" parent="p5-1" style="line;strokeWidth=2;strokeColor=#2E7D32;html=1;" value="" vertex="1">
          <mxGeometry height="10" width="2200" x="40" y="115" as="geometry" />
        </mxCell>
        <mxCell id="p5-path1-label" parent="p5-1" style="text;html=1;align=left;verticalAlign=middle;fontSize=16;fontStyle=1;fontFamily=Helvetica;fontColor=#2E7D32;" value="▼ Path 1 — `bgagent run` / `submit --watch` (interactive, Runtime-JWT, same-process SSE)" vertex="1">
          <mxGeometry height="22" width="1600" x="40" y="128" as="geometry" />
        </mxCell>
