        <mxCell id="p5-p2-m11" edge="1" parent="p5-1" style="endArrow=classic;html=1;fontSize=10;fontFamily=Helvetica;labelBackgroundColor=#FFFFFF;strokeColor=#8C4FFF;" value="11. loop: GET /events?after=&lt;id&gt; (~500ms)">
