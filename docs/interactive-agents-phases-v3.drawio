          <mxGeometry height="20" width="120" x="10" y="100" as="geometry" />
        </mxCell>
        <mxCell id="p2-api" parent="p2-cloud" style="rounded=1;fillColor=#EDE7F6;strokeColor=#8C4FFF;html=1;verticalAlign=top;fontStyle=1;fontSize=12;fontColor=#8C4FFF;fontFamily=Helvetica;container=1;collapsible=0;strokeWidth=1.5;" value="REST API (control plane)" vertex="1">
