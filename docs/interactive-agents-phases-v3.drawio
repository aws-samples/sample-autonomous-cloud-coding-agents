          <mxGeometry height="80" width="280" x="760" y="600" as="geometry" />
        </mxCell>
        <mxCell id="p4-r6c5" parent="p4-1" style="rounded=0;fillColor=light-dark(#FFFFFF,#2a2a2a);strokeColor=#666666;html=1;align=left;verticalAlign=middle;fontSize=11;fontFamily=Helvetica;spacingLeft=10;" value="nightly dependency update agent; CI step waits for PASS/FAIL terminal" vertex="1">
          <mxGeometry height="80" width="760" x="1040" y="600" as="geometry" />
        </mxCell>
        <mxCell id="p4-r7c1" parent="p4-1" style="rounded=0;fillColor=#EDE7F6;strokeColor=#666666;html=1;align=left;verticalAlign=middle;fontSize=11;fontStyle=1;fontColor=#8C4FFF;fontFamily=Helvetica;spacingLeft=10;" value="Agent-to-agent" vertex="1">
