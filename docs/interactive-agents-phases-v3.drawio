        <mxCell id="p2-rti-n" parent="p2-rti" style="text;html=1;fontSize=10;fontFamily=Helvetica;fontColor=#01A88D;align=left;verticalAlign=top;spacing=6;whiteSpace=wrap;" value="&lt;b&gt;Orchestrator path (IAM)&lt;/b&gt;&lt;br&gt;SigV4 auth, sync spawn&lt;br&gt;Accept: application/json&lt;br&gt;backs cron/CI/webhooks + plain `bgagent submit`&lt;br&gt;&lt;b&gt;CDK LifecycleConfig:&lt;/b&gt;&lt;br&gt;  idleRuntimeSessionTimeout=8h&lt;br&gt;  maxLifetime=8h&lt;br&gt;&lt;br&gt;Agent code (see below)" vertex="1">
          <mxGeometry height="98.5764705882353" width="190" x="10" y="94.52941176470588" as="geometry" />
        </mxCell>
        <mxCell id="p2-rtj" parent="p2-cloud" style="rounded=1;fillColor=#E0F2F1;strokeColor=#01A88D;html=1;verticalAlign=top;fontStyle=1;fontSize=12;fontColor=#01A88D;fontFamily=Helvetica;container=1;collapsible=0;strokeWidth=3;" value="Runtime-JWT (NEW, 1b)" vertex="1">
          <mxGeometry height="380" width="230" x="860" y="700" as="geometry" />
        </mxCell>
        <mxCell id="p2-rtj-i" parent="p2-rtj" style="shape=mxgraph.aws4.resourceIcon;resIcon=mxgraph.aws4.bedrock_agentcore;fillColor=#01A88D;strokeColor=#ffffff;aspect=fixed;html=1;verticalLabelPosition=bottom;verticalAlign=top;align=center;fontSize=10;fontFamily=Helvetica;" value="&lt;div&gt;AgentCore Runtime&lt;/div&gt;customJWTAuthorizer" vertex="1">
          <mxGeometry height="48" width="48" x="81" y="35" as="geometry" />
        </mxCell>
        <mxCell id="p2-rtj-n" parent="p2-rtj" style="text;html=1;fontSize=10;fontFamily=Helvetica;fontColor=#2E7D32;align=left;verticalAlign=top;spacing=6;whiteSpace=wrap;" value="&lt;b&gt;Interactive / SSE path (JWT)&lt;/b&gt;&lt;br&gt;discoveryUrl → Cognito JWKS&lt;br&gt;allowedClients = CLI client&lt;br&gt;direct CLI connection&lt;br&gt;&lt;b&gt;server.py hydrates&lt;/b&gt; repo_url, task_description,&lt;br&gt;issue_number, max_turns, max_budget_usd,&lt;br&gt;task_type, branch_name, pr_number from TaskTable by task_id&lt;br&gt;&lt;b&gt;RUN_ELSEWHERE guard:&lt;/b&gt; if TaskTable.execution_mode ≠ &#39;interactive&#39; → 409&lt;br&gt;(AgentCore wraps → 424 Failed Dependency)&lt;br&gt;&lt;b&gt;CDK LifecycleConfig:&lt;/b&gt; idleRuntimeSessionTimeout=8h, maxLifetime=8h&lt;br&gt;Sessions NOT transferable between runtimes." vertex="1">
          <mxGeometry height="240" width="210" x="10" y="136" as="geometry" />
        </mxCell>
        <mxCell id="p2-agent" parent="p2-cloud" style="rounded=1;fillColor=light-dark(#F5F5F5,#2a2a2a);strokeColor=#01A88D;strokeWidth=2;html=1;verticalAlign=top;fontStyle=1;fontSize=12;fontFamily=Helvetica;fontColor=#01A88D;container=1;collapsible=0;spacingLeft=10;spacingTop=6;whiteSpace=wrap;" value="Agent container (shared Docker image, both runtimes — CDK calls AgentRuntimeArtifact.fromAsset twice to work around L2 AssetImage.bind double-attach guard; DockerImageAsset dedupes by hash → single ECR image)" vertex="1">
          <mxGeometry height="974" width="652" x="1120" y="210" as="geometry" />
        </mxCell>
        <mxCell id="p2-srv" parent="p2-agent" style="rounded=1;fillColor=#E0F2F1;strokeColor=#01A88D;html=1;align=left;verticalAlign=top;fontSize=10;fontStyle=1;fontColor=#01A88D;fontFamily=Helvetica;spacing=8;whiteSpace=wrap;" value="&lt;b&gt;server.py — 4 roles&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-weight:normal&quot;&gt;&lt;b&gt;1. GET /ping&lt;/b&gt; → &quot;HealthyBusy&quot; while any pipeline thread alive (defence-in-depth vs idle eviction).&lt;br&gt;&lt;b&gt;2. POST /invocations, Accept: application/json&lt;/b&gt; → sync spawn via _spawn_background; orchestrator path (Runtime-IAM).&lt;br&gt;&lt;b&gt;3. POST /invocations, Accept: text/event-stream&lt;/b&gt; → &lt;b&gt;RUN_ELSEWHERE guard&lt;/b&gt; (read TaskTable.execution_mode; if ≠ &#39;interactive&#39; → HTTP 409 {code:RUN_ELSEWHERE}).&lt;br&gt;Then attach-don&#39;t-spawn: check per-microVM {task_id: _SSEAdapter} registry → if exists, subscribe a new observer queue (multi-subscriber); else spawn + register.&lt;br&gt;&lt;b&gt;4. Keepalive&lt;/b&gt; `: ping\n\n` every 15s on SSE streams.&lt;/span&gt;" vertex="1">
          <mxGeometry height="210" width="460" x="15" y="40" as="geometry" />
        </mxCell>
        <mxCell id="p2-pipe" parent="p2-agent" style="rounded=1;fillColor=#E0F2F1;strokeColor=#01A88D;html=1;align=left;verticalAlign=top;fontSize=10;fontStyle=1;fontColor=#01A88D;fontFamily=Helvetica;spacing=8;" value="&lt;b&gt;pipeline.py + runner.py&lt;/b&gt;&lt;br&gt;&lt;span style=&#39;font-weight:normal&#39;&gt;Sync run_task in BACKGROUND THREAD. Lifetime == microVM lifetime (8h max).&lt;br&gt;No Phase 1a regression; no async refactor.&lt;br&gt;Both emission paths called at every event point.&lt;br&gt;On completion, finally{} removes {task_id: adapter} from registry.&lt;/span&gt;" vertex="1">
          <mxGeometry height="100" width="460" x="15" y="260" as="geometry" />
        </mxCell>
        <mxCell id="p2-pw" parent="p2-agent" style="rounded=1;fillColor=#E3F2FD;strokeColor=#1F6FEB;strokeWidth=2;html=1;align=left;verticalAlign=top;fontSize=10;fontStyle=1;fontColor=#1F6FEB;fontFamily=Helvetica;spacing=8;" value="&lt;b&gt;ProgressWriter (1a, unchanged)&lt;/b&gt;&lt;br&gt;&lt;span style=&#39;font-weight:normal&#39;&gt;PutItem → TaskEventsTable&lt;br&gt;fail-open + circuit breaker&lt;br&gt;DURABILITY layer&lt;/span&gt;" vertex="1">
          <mxGeometry height="100" width="220" x="15" y="370" as="geometry" />
        </mxCell>
        <mxCell id="p2-sse" parent="p2-agent" style="rounded=1;fillColor=#C8E6C9;strokeColor=#2E7D32;strokeWidth=3;html=1;align=left;verticalAlign=top;fontSize=10;fontStyle=1;fontColor=#2E7D32;fontFamily=Helvetica;spacing=8;whiteSpace=wrap;" value="&lt;b&gt;_SSEAdapter (rev-5)&lt;/b&gt;&lt;br&gt;&lt;span style=&#39;font-weight:normal&#39;&gt;Per-task_id, multi-subscriber (per-observer queue).&lt;br&gt;Stored in per-microVM {task_id: adapter} registry under _threads_lock.&lt;br&gt;Reconnect within same microVM → attach-don&#39;t-spawn.&lt;br&gt;serializes to AG-UI JSON; REAL-TIME layer.&lt;/span&gt;" vertex="1">
          <mxGeometry height="126" width="220" x="255" y="370" as="geometry" />
        </mxCell>
        <mxCell id="p2-q" parent="p2-agent" style="rounded=1;fillColor=#C8E6C9;strokeColor=#2E7D32;strokeWidth=3;html=1;align=center;verticalAlign=middle;fontSize=11;fontStyle=1;fontColor=#2E7D32;fontFamily=Helvetica;" value="asyncio.Queue (per observer)&#xa;multi-subscriber fan-out" vertex="1">
          <mxGeometry height="55" width="230" x="130" y="553" as="geometry" />
        </mxCell>
        <mxCell id="p2-emit-note" parent="p2-agent" style="text;html=1;fontSize=10;fontFamily=Helvetica;fontColor=#01A88D;align=left;verticalAlign=top;spacing=6;" value="&lt;b&gt;Dual emission at every event point:&lt;/b&gt;&lt;br&gt;progress.write_agent_milestone(&#39;repo_setup_complete&#39;)&lt;br&gt;  → ProgressWriter.PutItem(DDB)&lt;br&gt;  → SSEAdapter.push(Queue)&lt;br&gt;&lt;br&gt;If no SSE session open, Queue push is a no-op.&lt;br&gt;DDB write always happens (durability guarantee)." vertex="1">
          <mxGeometry height="130" width="460" x="12" y="620" as="geometry" />
        </mxCell>
        <mxCell id="p2-pipe-emit" parent="p2-agent" style="text;html=1;fontSize=9;fontFamily=Helvetica;fontColor=#01A88D;align=left;verticalAlign=top;spacing=6;" value="&lt;b&gt;Claude SDK integration:&lt;/b&gt; TextMessage triad&lt;br&gt;(TEXT_MESSAGE_START / CONTENT / END),&lt;br&gt;TOOL_CALL_START / ARGS / END + RESULT,&lt;br&gt;RUN_STARTED / RUN_FINISHED / RUN_ERROR,&lt;br&gt;agent_cost_update → CUSTOM event" vertex="1">
          <mxGeometry height="100" width="216" x="272" y="621" as="geometry" />
        </mxCell>
        <mxCell id="TOOdmFCA923Vuo8fdHCV-1" parent="p2-agent" style="sketch=0;points=[[0,0,0],[0.25,0,0],[0.5,0,0],[0.75,0,0],[1,0,0],[0,1,0],[0.25,1,0],[0.5,1,0],[0.75,1,0],[1,1,0],[0,0.25,0],[0,0.5,0],[0,0.75,0],[1,0.25,0],[1,0.5,0],[1,0.75,0]];outlineConnect=0;fontColor=#232F3E;fillColor=light-dark(#01a88d, #d86d0c);strokeColor=#ffffff;dashed=0;verticalLabelPosition=bottom;verticalAlign=top;align=center;html=1;fontSize=12;fontStyle=0;aspect=fixed;shape=mxgraph.aws4.resourceIcon;resIcon=mxgraph.aws4.containers;" value="" vertex="1">
          <mxGeometry height="25" width="25" x="33" as="geometry" />
        </mxCell>
        <mxCell id="p2-cap" parent="p2-agent" style="rounded=1;fillColor=#FFECB3;strokeColor=#F9A825;strokeWidth=2;html=1;align=left;verticalAlign=top;fontSize=11;fontFamily=Helvetica;fontColor=#BF5700;spacing=10;whiteSpace=wrap;fontStyle=1;" value="60-minute streaming cap&lt;br&gt;&lt;span style=&quot;font-weight:normal;font-size:10px&quot;&gt;AWS-documented, NON-ADJUSTABLE service quota on AgentCore Runtime (enforced at proxy layer). One of three independent ceilings: 15-min sync / 60-min stream / 8-h async. Behavior at cap is partially documented: may emit clean RUN_ERROR or abruptly close TCP. CLI MUST plan for both.&amp;nbsp;&lt;/span&gt;&lt;div&gt;&lt;span style=&quot;font-weight:normal;font-size:10px&quot;&gt;Reconnect uses same runtimeSessionId via app-level catch-up (no Last-Event-ID).&lt;/span&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="102" width="492" y="794" as="geometry" />
        </mxCell>
        <mxCell id="p2-ws" parent="p2-agent" style="rounded=1;fillColor=light-dark(#FFFFFF,#2a2a2a);strokeColor=#ED7100;strokeDasharray=8 4;strokeWidth=2;html=1;align=left;verticalAlign=top;fontSize=11;fontFamily=Helvetica;fontColor=#BF5700;spacing=10;whiteSpace=wrap;fontStyle=1;" value="Future: WebSocket bidirectional path (Phase 1c+)&#xa;&lt;span style=&#39;font-weight:normal;font-size:10px&#39;&gt;AgentCore exposes /ws alongside /invocations for nudges. Complementary to REST+SSE. Not in scope for Phase 1b. See page 8.&lt;/span&gt;" vertex="1">
          <mxGeometry height="70" width="660" y="900" as="geometry" />
        </mxCell>
