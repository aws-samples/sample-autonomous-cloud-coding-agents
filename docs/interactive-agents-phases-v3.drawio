        </mxCell>
        <mxCell id="p4-r7c2" parent="p4-1" style="rounded=0;fillColor=light-dark(#FFFFFF,#2a2a2a);strokeColor=#666666;html=1;align=left;verticalAlign=middle;fontSize=11;fontColor=#8C4FFF;fontFamily=Helvetica;spacingLeft=10;" value="REST POST /tasks&#xa;(IAM or JWT)" vertex="1">
