        <mxCell id="p2-legend" parent="p2-1" style="rounded=1;fillColor=light-dark(#FFFFFF,#2a2a2a);strokeColor=#666666;html=1;align=left;verticalAlign=top;fontSize=11;fontFamily=Helvetica;spacing=8;whiteSpace=wrap;" value="&lt;b&gt;Color legend:&lt;/b&gt; &lt;span style=&#39;color:#999&#39;&gt;gray = baseline/pre-1a&lt;/span&gt; · &lt;span style=&#39;color:#1F6FEB&#39;&gt;blue = Phase 1a (preserved)&lt;/span&gt; · &lt;span style=&#39;color:#2E7D32&#39;&gt;green = Phase 1b NEW&lt;/span&gt; · &lt;span style=&#39;color:#C925D1&#39;&gt;magenta = fan-out (1b)&lt;/span&gt; · &lt;span style=&#39;color:#F9A825&#39;&gt;amber dashed = shared/future&lt;/span&gt;" vertex="1">
          <mxGeometry height="40" width="1700" x="53" y="1333" as="geometry" />
        </mxCell>
        <mxCell id="p2-inv" parent="p2-1" style="rounded=1;fillColor=light-dark(#FFFDE7,#2a2a14);strokeColor=#F9A825;strokeWidth=2;html=1;align=left;verticalAlign=top;fontSize=11;fontFamily=Helvetica;fontColor=light-dark(#BF5700,#FFD180);spacing=10;whiteSpace=wrap;fontStyle=0;" value="&lt;b style=&#39;font-size:13px&#39;&gt;Rev-5 invariants&lt;/b&gt;&lt;br&gt;&lt;br&gt;• &lt;b&gt;execution_mode&lt;/b&gt; is set at task create time and is &lt;b&gt;immutable&lt;/b&gt; thereafter.&lt;br&gt;• &lt;b&gt;Interactive&lt;/b&gt; tasks run on Runtime-JWT; pipeline lifetime == microVM lifetime (8h max).&lt;br&gt;• &lt;b&gt;Orchestrator&lt;/b&gt; tasks run on Runtime-IAM (via orchestrator Lambda async invoke).&lt;br&gt;• &lt;b&gt;No cross-runtime live attach&lt;/b&gt; — reconnection attach is per-microVM only; Phase 1c future.&lt;br&gt;• &lt;b&gt;Client-side transport decision:&lt;/b&gt; CLI reads execution_mode from GET /tasks/{id} before attempting SSE.&lt;br&gt;• &lt;b&gt;Defence-in-depth:&lt;/b&gt; server-side 409 RUN_ELSEWHERE (→ 424 via AgentCore) if mismatch slips through.&lt;br&gt;• &lt;b&gt;/ping = HealthyBusy&lt;/b&gt; while any pipeline thread alive — survives idleRuntimeSessionTimeout misconfig.&lt;br&gt;• &lt;b&gt;TaskDetail REST now includes&lt;/b&gt; execution_mode: ExecutionMode | null." vertex="1">
          <mxGeometry height="260" width="520" x="-259" y="100" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
  <diagram name="3. Control vs streaming planes" id="p3-page">
    <mxGraphModel dx="1543" dy="1105" grid="0" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="0" pageScale="1" pageWidth="1900" pageHeight="1400" math="0" shadow="0">
      <root>
        <mxCell id="p3-0" />
        <mxCell id="p3-1" parent="p3-0" />
        <mxCell id="p3-t" parent="p3-1" style="text;html=1;align=left;verticalAlign=top;fontSize=26;fontStyle=1;fontFamily=Helvetica;" value="Four orthogonal planes — every channel uses control; streaming is additive" vertex="1">
          <mxGeometry height="40" width="1800" x="40" y="20" as="geometry" />
        </mxCell>
        <mxCell id="p3-ts" parent="p3-1" style="text;html=1;align=left;verticalAlign=top;fontSize=13;fontFamily=Helvetica;fontColor=#555555;" value="Submission (REST) is universal. Consumption uses streaming plane (interactive SSE), fan-out plane (async push to non-interactive consumers), or future bidirectional plane (WebSocket nudges). Planes are orthogonal — a single task may use 1+." vertex="1">
          <mxGeometry height="50" width="1800" x="40" y="60" as="geometry" />
        </mxCell>
        <mxCell id="p3-bar" parent="p3-1" style="line;strokeWidth=2;strokeColor=#666666;html=1;" value="" vertex="1">
