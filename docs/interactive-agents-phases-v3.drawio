        <mxCell id="p3-bidi-rt" parent="p3-bidi" style="rounded=1;fillColor=light-dark(#FFFFFF,#2a2a2a);strokeColor=#ED7100;strokeDasharray=6 3;html=1;align=center;verticalAlign=middle;fontSize=11;fontStyle=1;fontFamily=Helvetica;fontColor=#BF5700;" value="Runtime-JWT /ws" vertex="1">
