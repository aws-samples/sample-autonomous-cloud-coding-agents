        <mxCell id="p6-phaseC" parent="p6-1" style="rounded=1;fillColor=#C8E6C944;strokeColor=#2E7D32;strokeDasharray=6 4;html=1;align=left;verticalAlign=top;fontSize=13;fontStyle=1;fontColor=#2E7D32;fontFamily=Helvetica;spacingLeft=10;spacingTop=6;" value="Phase C — resume" vertex="1">
          <mxGeometry height="350" width="1900" x="40" y="900" as="geometry" />
