        <mxCell id="p3-bidi" parent="p3-1" style="rounded=1;fillColor=light-dark(#FFFFFF,#2a2a2a);strokeColor=#ED7100;strokeWidth=3;strokeDasharray=10 5;html=1;verticalAlign=top;fontStyle=1;fontSize=16;fontFamily=Helvetica;fontColor=#BF5700;container=1;collapsible=0;spacingLeft=10;spacingTop=6;" value="FUTURE: BIDIRECTIONAL PLANE (WebSocket /ws, Phase 1c+) — NOT YET BUILT" vertex="1">
          <mxGeometry height="240" width="1800" x="40" y="940" as="geometry" />
        </mxCell>
        <mxCell id="p3-bidi-d" parent="p3-bidi" style="text;html=1;fontSize=12;fontFamily=Helvetica;fontColor=#BF5700;align=left;verticalAlign=top;spacing=8;" value="&lt;b&gt;Transport:&lt;/b&gt; WebSocket /ws (client↔server).&amp;nbsp;&lt;div&gt;&lt;b&gt;Use case:&lt;/b&gt; mid-task user steering, tool-call approvals, HITL.&amp;nbsp;&lt;/div&gt;&lt;div&gt;&lt;b&gt;Payload:&lt;/b&gt; server→client identical to SSE (17 AG-UI events), client→server adds TOOL_USE_APPROVAL_RESPONSE, USER_NUDGE.&amp;nbsp;&lt;/div&gt;&lt;div&gt;&lt;b&gt;Status:&lt;/b&gt; out of scope for 1b. Trigger to build: Cedar-driven HITL spec finalized (design §9.3 rev 4).&lt;/div&gt;" vertex="1">
          <mxGeometry height="90" width="1760" x="20" y="40" as="geometry" />
        </mxCell>
