        <mxCell id="p6-C3" parent="p6-1" style="rounded=1;fillColor=#E3F2FD;strokeColor=#1F6FEB;html=1;align=left;fontSize=10;fontFamily=Helvetica;fontColor=#1F6FEB;spacing=8;fontStyle=1;whiteSpace=wrap;" value="C3. CLI reconciles: deduplicates events by event_id. If catch-up returned 01J123...B and SSE later delivers 01J123...B again, drop it. Dedupe buffer = last N event_ids seen (ULID is monotonic so N=50 is plenty)." vertex="1">
          <mxGeometry height="70" width="1860" x="60" y="1020" as="geometry" />
        </mxCell>
        <mxCell id="p6-C4" edge="1" parent="p6-1" style="endArrow=classic;html=1;fontSize=10;fontFamily=Helvetica;labelBackgroundColor=#FFFFFF;strokeColor=#2E7D32;" value="C4. watching continues until RUN_FINISHED">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="1405" y="1130" as="sourcePoint" />
            <mxPoint x="110" y="1130" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <mxCell id="p6-C5" edge="1" parent="p6-1" style="endArrow=classic;html=1;fontSize=10;fontFamily=Helvetica;labelBackgroundColor=#FFFFFF;fontStyle=1;" value="C5. RUN_FINISHED → CLI exits 0 (events gap bridged, user never saw the drop)">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="1405" y="1180" as="sourcePoint" />
            <mxPoint x="110" y="1180" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <mxCell id="p6-n1" parent="p6-1" style="shape=note;size=14;fillColor=#FFECB3;strokeColor=#F9A825;html=1;fontSize=11;fontFamily=Helvetica;fontColor=#BF5700;align=left;verticalAlign=top;spacing=8;whiteSpace=wrap;fontStyle=1;" value="AgentCore has NO SSE-native resume — no Last-Event-ID, no checkpointing.&#xa;&lt;span style=&#39;font-weight:normal;font-size:10px&#39;&gt;App-level catch-up via GET /tasks/{id}/events?after=&amp;lt;event_id&amp;gt; against TaskEventsTable is the ONLY reliable mechanism. This is why ProgressWriter&#39;s durable DDB writes are load-bearing.&lt;/span&gt;" vertex="1">
          <mxGeometry height="140" width="920" x="40" y="1280" as="geometry" />
        </mxCell>
        <mxCell id="p6-n2" parent="p6-1" style="shape=note;size=14;fillColor=#FFECB3;strokeColor=#F9A825;html=1;fontSize=11;fontFamily=Helvetica;fontColor=#BF5700;align=left;verticalAlign=top;spacing=8;whiteSpace=wrap;fontStyle=1;" value="60-min streaming cap is a non-adjustable AWS service quota, NOT an SSE limitation.&#xa;&lt;span style=&#39;font-weight:normal;font-size:10px&#39;&gt;Enforced at the AgentCore proxy layer. Behavior at the cap is partially documented: may emit clean RUN_ERROR with code, or close TCP abruptly. CLI reconnect logic handles both identically via this flow.&lt;/span&gt;" vertex="1">
          <mxGeometry height="140" width="920" x="990" y="1280" as="geometry" />
        </mxCell>
        <mxCell id="p6-n3" parent="p6-1" style="shape=note;size=14;fillColor=#E3F2FD;strokeColor=#1F6FEB;html=1;fontSize=11;fontFamily=Helvetica;fontColor=#1F6FEB;align=left;verticalAlign=top;spacing=8;whiteSpace=wrap;fontStyle=1;" value="AG-UI wire format has no id: frames.&#xa;&lt;span style=&#39;font-weight:normal;font-size:10px&#39;&gt;The wire protocol maps cleanly to app-level catch-up — events are content-only on the wire; durable IDs live only in DDB. Browsers&#39; EventSource Last-Event-ID mechanism is unused (and unusable here) because AgentCore never emits id: lines.&lt;/span&gt;" vertex="1">
          <mxGeometry height="110" width="1870" x="40" y="1440" as="geometry" />
        </mxCell>
        <mxCell id="p6-n4" parent="p6-1" style="shape=note;size=14;fillColor=light-dark(#FFFDE7,#2a2a14);strokeColor=#F9A825;strokeWidth=2;html=1;fontSize=11;fontFamily=Helvetica;fontColor=light-dark(#BF5700,#FFD180);align=left;verticalAlign=top;spacing=10;whiteSpace=wrap;fontStyle=1;" value="Rev-5: reconnection-attach scope is per-microVM.&#xa;&lt;span style=&#39;font-weight:normal;font-size:10px&#39;&gt;AgentCore&#39;s &quot;same runtimeSessionId → same microVM&quot; routing is scoped &lt;b&gt;per runtime ARN&lt;/b&gt;. Within a microVM, server.py&#39;s {task_id: _SSEAdapter} registry lets a second SSE connect subscribe to the existing pipeline (multi-subscriber; no duplicate spawn).&lt;br&gt;&lt;br&gt;Across microVMs (eviction / maxLifetime / new pool), there is &lt;b&gt;no cross-runtime live attach&lt;/b&gt; in Phase 1b. Reconnection falls back to DDB catch-up only (the Phase B flow above). Phase 1c will add pub/sub (IoT Core MQTT or ElastiCache Redis) for cross-microVM real-time observation.&lt;/span&gt;" vertex="1">
          <mxGeometry height="160" width="1870" x="40" y="1570" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
  <diagram name="7. Decision rationale" id="p7-page">
    <mxGraphModel dx="1609" dy="900" grid="0" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="0" pageScale="1" pageWidth="2000" pageHeight="1400" math="0" shadow="0">
      <root>
        <mxCell id="p7-0" />
        <mxCell id="p7-1" parent="p7-0" />
        <mxCell id="p7-t" parent="p7-1" style="text;html=1;align=left;verticalAlign=top;fontSize=26;fontStyle=1;fontFamily=Helvetica;" value="Phase 1b decision rationale — chosen vs rejected options" vertex="1">
          <mxGeometry x="40" y="20" width="1900" height="40" as="geometry" />
        </mxCell>
        <mxCell id="p7-ts" parent="p7-1" style="text;html=1;align=left;verticalAlign=top;fontSize=13;fontFamily=Helvetica;fontColor=#555555;" value="For each of the three architecture decisions (D1 auth/runtime, D2 server.py SSE, D3 CLI SSE client), the chosen option is highlighted in green with a star; rejected options are grayed with brief &quot;why rejected&quot; notes." vertex="1">
          <mxGeometry x="40" y="60" width="1900" height="50" as="geometry" />
        </mxCell>
        <mxCell id="p7-bar" parent="p7-1" style="line;strokeWidth=2;strokeColor=#666666;html=1;" value="" vertex="1">
          <mxGeometry x="40" y="115" width="1900" height="10" as="geometry" />
        </mxCell>
        <mxCell id="p7-d1h" parent="p7-1" style="rounded=1;fillColor=#232F3E;strokeColor=#232F3E;html=1;align=center;verticalAlign=middle;fontSize=16;fontStyle=1;fontColor=#FFFFFF;fontFamily=Helvetica;" value="D1 — Auth/runtime split" vertex="1">
          <mxGeometry x="40" y="150" width="620" height="55" as="geometry" />
        </mxCell>
        <mxCell id="p7-d2h" parent="p7-1" style="rounded=1;fillColor=#232F3E;strokeColor=#232F3E;html=1;align=center;verticalAlign=middle;fontSize=16;fontStyle=1;fontColor=#FFFFFF;fontFamily=Helvetica;" value="D2 — server.py SSE architecture" vertex="1">
          <mxGeometry x="680" y="150" width="620" height="55" as="geometry" />
        </mxCell>
        <mxCell id="p7-d3h" parent="p7-1" style="rounded=1;fillColor=#232F3E;strokeColor=#232F3E;html=1;align=center;verticalAlign=middle;fontSize=16;fontStyle=1;fontColor=#FFFFFF;fontFamily=Helvetica;" value="D3 — CLI SSE client" vertex="1">
          <mxGeometry x="1320" y="150" width="620" height="55" as="geometry" />
        </mxCell>
        <mxCell id="p7-d1-chosen" parent="p7-1" style="rounded=1;fillColor=#C8E6C9;strokeColor=#2E7D32;strokeWidth=3;html=1;align=left;verticalAlign=top;fontSize=12;fontFamily=Helvetica;fontColor=#2E7D32;spacing=12;whiteSpace=wrap;fontStyle=1;" value="★ CHOSEN — Two AgentCore Runtimes from same Docker image&#xa;&#xa;&lt;span style=&#39;font-weight:normal;font-size:11px&#39;&gt;• Runtime-IAM (orchestrator path, SigV4 from Lambda)&lt;br&gt;• Runtime-JWT (direct CLI SSE, customJWTAuthorizer→Cognito JWKS)&lt;br&gt;• Sessions scoped to one runtime ARN; not transferable&lt;br&gt;• ProgressWriter writes DDB regardless of runtime, so cross-path observation works (polling); cross-path control does not&lt;br&gt;&lt;br&gt;&lt;b&gt;Why chosen:&lt;/b&gt; AgentCore authorizerConfiguration is mutually exclusive. Two runtimes = cleanest solution. Same image = zero code delta. 2x runtime cost acceptable for Phase 1b.&lt;/span&gt;" vertex="1">
          <mxGeometry x="40" y="220" width="620" height="300" as="geometry" />
        </mxCell>
        <mxCell id="p7-d1-r1" parent="p7-1" style="rounded=1;fillColor=light-dark(#F5F5F5,#2a2a2a);strokeColor=#999999;html=1;align=left;verticalAlign=top;fontSize=11;fontFamily=Helvetica;fontColor=#666666;spacing=10;whiteSpace=wrap;" value="&lt;span style=&#39;text-decoration:line-through&#39;&gt;Option B — API Gateway bridge Lambda&lt;/span&gt;&#xa;&lt;span style=&#39;font-size:10px&#39;&gt;Single runtime; JWT→SigV4 bridge Lambda in front.&lt;/span&gt;&#xa;&#xa;&lt;b&gt;Rejected:&lt;/b&gt; &lt;span style=&#39;font-size:10px&#39;&gt;API GW 29s hard timeout is fatal for SSE. Would need Lambda response streaming + custom proxying. Bridge Lambda is a new failure point. Lambda 15-min hard timeout conflicts with 60-min SSE cap.&lt;/span&gt;" vertex="1">
          <mxGeometry x="40" y="540" width="620" height="180" as="geometry" />
        </mxCell>
        <mxCell id="p7-d1-r2" parent="p7-1" style="rounded=1;fillColor=light-dark(#F5F5F5,#2a2a2a);strokeColor=#999999;html=1;align=left;verticalAlign=top;fontSize=11;fontFamily=Helvetica;fontColor=#666666;spacing=10;whiteSpace=wrap;" value="&lt;span style=&#39;text-decoration:line-through&#39;&gt;Option C — Reuse single Runtime-IAM; CLI signs SigV4&lt;/span&gt;&#xa;&lt;span style=&#39;font-size:10px&#39;&gt;Have the CLI do SigV4 signing directly from user credentials.&lt;/span&gt;&#xa;&#xa;&lt;b&gt;Rejected:&lt;/b&gt; &lt;span style=&#39;font-size:10px&#39;&gt;Requires every CLI user to have AWS credentials with InvokeAgentRuntime IAM. Breaks principle of user-identity-based auth. Painful onboarding; conflicts with Cognito-based identity model.&lt;/span&gt;" vertex="1">
          <mxGeometry x="40" y="740" width="620" height="170" as="geometry" />
        </mxCell>
        <mxCell id="p7-d2-chosen" parent="p7-1" style="rounded=1;fillColor=#C8E6C9;strokeColor=#2E7D32;strokeWidth=3;html=1;align=left;verticalAlign=top;fontSize=12;fontFamily=Helvetica;fontColor=#2E7D32;spacing=12;whiteSpace=wrap;fontStyle=1;" value="★ CHOSEN — Background thread + asyncio.Queue bridge&#xa;&#xa;&lt;span style=&#39;font-weight:normal;font-size:11px&#39;&gt;• Sync run_task stays in bg thread (no Phase 1a regression)&lt;br&gt;• New SSEAdapter is sibling to ProgressWriter&lt;br&gt;• Both receive same events at every emission point&lt;br&gt;• ProgressWriter → DDB (durability)&lt;br&gt;• SSEAdapter → per-session asyncio.Queue&lt;br&gt;• server.py SSE endpoint drains Queue, emits AG-UI frames + : ping\n\n every 15s&lt;br&gt;&lt;br&gt;&lt;b&gt;Why chosen:&lt;/b&gt; Preserves deployed sync code. Low blast radius. Claude SDK integration already works synchronously — don&#39;t fix what isn&#39;t broken.&lt;/span&gt;" vertex="1">
          <mxGeometry x="680" y="220" width="620" height="300" as="geometry" />
        </mxCell>
        <mxCell id="p7-d2-r1" parent="p7-1" style="rounded=1;fillColor=light-dark(#F5F5F5,#2a2a2a);strokeColor=#999999;html=1;align=left;verticalAlign=top;fontSize=11;fontFamily=Helvetica;fontColor=#666666;spacing=10;whiteSpace=wrap;" value="&lt;span style=&#39;text-decoration:line-through&#39;&gt;Option A — Inline async generator (full rewrite)&lt;/span&gt;&#xa;&lt;span style=&#39;font-size:10px&#39;&gt;Convert run_task + pipeline.py + runner.py to async generators; yield events all the way up.&lt;/span&gt;&#xa;&#xa;&lt;b&gt;Rejected:&lt;/b&gt; &lt;span style=&#39;font-size:10px&#39;&gt;Every yield propagates up the stack. Requires refactoring working Phase 1a code. Claude SDK would need async validation. Large regression surface. Backpressure nice in theory but not worth the churn.&lt;/span&gt;" vertex="1">
          <mxGeometry x="680" y="540" width="620" height="180" as="geometry" />
        </mxCell>
        <mxCell id="p7-d2-r2" parent="p7-1" style="rounded=1;fillColor=light-dark(#F5F5F5,#2a2a2a);strokeColor=#999999;html=1;align=left;verticalAlign=top;fontSize=11;fontFamily=Helvetica;fontColor=#666666;spacing=10;whiteSpace=wrap;" value="&lt;span style=&#39;text-decoration:line-through&#39;&gt;Option C — Poll ProgressWriter from SSE endpoint&lt;/span&gt;&#xa;&lt;span style=&#39;font-size:10px&#39;&gt;Have SSE endpoint poll DDB Table and forward new events.&lt;/span&gt;&#xa;&#xa;&lt;b&gt;Rejected:&lt;/b&gt; &lt;span style=&#39;font-size:10px&#39;&gt;Polls DDB inside agent — wasteful. Latency equals poll interval (the very thing SSE is supposed to fix). Each SSE connection adds DDB load. Defeats the purpose of streaming entirely.&lt;/span&gt;" vertex="1">
          <mxGeometry x="680" y="740" width="620" height="170" as="geometry" />
        </mxCell>
        <mxCell id="p7-d3-chosen" parent="p7-1" style="rounded=1;fillColor=#C8E6C9;strokeColor=#2E7D32;strokeWidth=3;html=1;align=left;verticalAlign=top;fontSize=12;fontFamily=Helvetica;fontColor=#2E7D32;spacing=12;whiteSpace=wrap;fontStyle=1;" value="★ CHOSEN — Hybrid: @ag-ui/core types + native fetch/eventsource-parser transport&#xa;&#xa;&lt;span style=&#39;font-weight:normal;font-size:11px&#39;&gt;• Import @ag-ui/core for 17 event TYPES + Zod SCHEMAS only&lt;br&gt;• Own the transport: native fetch + eventsource-parser (32.7M wk downloads)&lt;br&gt;• CLI wrapper: exp backoff reconnect, JWT refresh, 60-min stream restart, dedupe buffer&lt;br&gt;&lt;br&gt;&lt;b&gt;Why chosen:&lt;/b&gt; Bets on the stable wire format (14+ frameworks adopted). Insulates from 0.0.x runtime churn. Matches AWS FAST template pattern. No HttpAgent wrapping required.&lt;/span&gt;" vertex="1">
          <mxGeometry x="1320" y="220" width="620" height="300" as="geometry" />
        </mxCell>
        <mxCell id="p7-d3-r1" parent="p7-1" style="rounded=1;fillColor=light-dark(#F5F5F5,#2a2a2a);strokeColor=#999999;html=1;align=left;verticalAlign=top;fontSize=11;fontFamily=Helvetica;fontColor=#666666;spacing=10;whiteSpace=wrap;" value="&lt;span style=&#39;text-decoration:line-through&#39;&gt;Option A — Full @ag-ui/client HttpAgent&lt;/span&gt;&#xa;&lt;span style=&#39;font-size:10px&#39;&gt;Use the official client library and wrap HttpAgent with our reconnect logic.&lt;/span&gt;&#xa;&#xa;&lt;b&gt;Rejected:&lt;/b&gt; &lt;span style=&#39;font-size:10px&#39;&gt;@ag-ui/client is 0.0.x pre-1.0. Single-shot request model, no built-in reconnect/backoff/token-refresh. We&#39;d wrap it anyway. Every version bump is a breaking-change risk.&lt;/span&gt;" vertex="1">
          <mxGeometry x="1320" y="540" width="620" height="180" as="geometry" />
        </mxCell>
        <mxCell id="p7-d3-r2" parent="p7-1" style="rounded=1;fillColor=light-dark(#F5F5F5,#2a2a2a);strokeColor=#999999;html=1;align=left;verticalAlign=top;fontSize=11;fontFamily=Helvetica;fontColor=#666666;spacing=10;whiteSpace=wrap;" value="&lt;span style=&#39;text-decoration:line-through&#39;&gt;Option B — Pure native fetch, no AG-UI deps&lt;/span&gt;&#xa;&lt;span style=&#39;font-size:10px&#39;&gt;Copy the 17 event type definitions into cli/src/types.ts manually.&lt;/span&gt;&#xa;&#xa;&lt;b&gt;Rejected:&lt;/b&gt; &lt;span style=&#39;font-size:10px&#39;&gt;Forever-growing type parity burden. AG-UI went from 4 to 16 types in 2025. Hand-maintained Zod schemas drift from spec. Better to consume the authoritative package for the data model and own only the transport.&lt;/span&gt;" vertex="1">
          <mxGeometry x="1320" y="740" width="620" height="170" as="geometry" />
        </mxCell>
        <mxCell id="p7-summary" parent="p7-1" style="rounded=1;fillColor=#FFECB3;strokeColor=#F9A825;html=1;align=left;verticalAlign=top;fontSize=12;fontFamily=Helvetica;fontColor=#BF5700;spacing=12;whiteSpace=wrap;fontStyle=1;" value="Common thread across all three chosen options&#xa;&lt;span style=&#39;font-weight:normal;font-size:11px&#39;&gt;• &lt;b&gt;Lowest regression risk:&lt;/b&gt; each choice preserves the Phase 1a behavior that is already deployed and working&lt;br&gt;• &lt;b&gt;Bet on stable interfaces, not unstable runtimes:&lt;/b&gt; AgentCore auth config (stable), AG-UI wire format (stable), eventsource-parser (mature), vs. @ag-ui/client (0.0.x, churning)&lt;br&gt;• &lt;b&gt;Additive, not replacive:&lt;/b&gt; new runtime next to old, new adapter next to existing writer, new streaming plane next to polling plane. No &quot;rip and replace.&quot;&lt;/span&gt;" vertex="1">
          <mxGeometry x="40" y="940" width="1900" height="170" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
  <diagram name="8. Phase 1c+ preview (NOT in scope)" id="p8-page">
    <mxGraphModel dx="2417" dy="1311" grid="0" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="0" pageScale="1" pageWidth="2000" pageHeight="1300" math="0" shadow="0">
      <root>
        <mxCell id="p8-0" />
        <mxCell id="p8-1" parent="p8-0" />
        <mxCell id="p8-t" parent="p8-1" style="text;html=1;align=left;verticalAlign=top;fontSize=28;fontStyle=1;fontFamily=Helvetica;fontColor=#BF5700;" value="Phase 1c+ preview — bidirectional nudges (WebSocket)" vertex="1">
          <mxGeometry height="40" width="1900" x="40" y="20" as="geometry" />
        </mxCell>
        <mxCell id="p8-ts" parent="p8-1" style="text;html=1;align=left;verticalAlign=top;fontSize=14;fontFamily=Helvetica;fontColor=#555555;" value="Future state showing WebSocket /ws path added alongside SSE for bidirectional mid-task steering. NOT being built in Phase 1b — this page is informational only, to clarify what Phase 1b is deliberately NOT doing." vertex="1">
          <mxGeometry height="50" width="1900" x="40" y="60" as="geometry" />
        </mxCell>
        <mxCell id="p8-banner" parent="p8-1" style="rounded=1;fillColor=#FFECB3;strokeColor=#ED7100;strokeWidth=4;strokeDasharray=10 5;html=1;align=center;verticalAlign=middle;fontSize=22;fontStyle=1;fontFamily=Helvetica;fontColor=#BF5700;spacing=12;" value="⚠ NOT IN SCOPE FOR CURRENT (PHASE 1b) WORK ⚠" vertex="1">
          <mxGeometry height="60" width="1900" x="40" y="125" as="geometry" />
        </mxCell>
        <mxCell id="p8-cloud" parent="p8-1" style="points=[[0,0],[0.25,0],[0.5,0],[0.75,0],[1,0],[1,0.25],[1,0.5],[1,0.75],[1,1],[0.75,1],[0.5,1],[0.25,1],[0,1],[0,0.75],[0,0.5],[0,0.25]];outlineConnect=0;gradientColor=none;html=1;whiteSpace=wrap;fontSize=12;shape=mxgraph.aws4.group;grIcon=mxgraph.aws4.group_aws_cloud;strokeColor=#ED7100;fillColor=light-dark(#FFFFFF,#2a2a2a);fillStyle=auto;verticalAlign=top;align=left;spacingLeft=30;fontColor=#BF5700;dashed=1;container=1;pointerEvents=0;collapsible=0;fontFamily=Helvetica;strokeWidth=2;" value="AWS Cloud (future state)" vertex="1">
          <mxGeometry height="740" width="1550" x="280" y="220" as="geometry" />
        </mxCell>
        <mxCell id="p8-cog" parent="p8-cloud" style="rounded=1;fillColor=light-dark(#FFEBEE,#FFEBEE);strokeColor=#DD344C;strokeDasharray=8 4;html=1;verticalAlign=top;fontStyle=1;fontSize=12;fontColor=#DD344C;fontFamily=Helvetica;container=1;collapsible=0;strokeWidth=2;" value="Auth (1b, still used)" vertex="1">
          <mxGeometry height="130" width="160" x="60" y="70" as="geometry" />
        </mxCell>
        <mxCell id="p8-cog-i" parent="p8-cog" style="shape=mxgraph.aws4.resourceIcon;resIcon=mxgraph.aws4.cognito;fillColor=#DD344C;strokeColor=#ffffff;aspect=fixed;html=1;verticalLabelPosition=bottom;verticalAlign=top;align=center;fontSize=10;fontFamily=Helvetica;" value="Cognito JWT" vertex="1">
          <mxGeometry height="48" width="48" x="56" y="30" as="geometry" />
        </mxCell>
        <mxCell id="p8-rtj" parent="p8-cloud" style="rounded=1;fillColor=light-dark(#E0F2F1,#E0F2F1);strokeColor=#01A88D;strokeWidth=3;strokeDasharray=10 5;html=1;verticalAlign=top;fontStyle=1;fontSize=14;fontFamily=Helvetica;fontColor=#01A88D;container=1;collapsible=0;" value="Runtime-JWT (1b)" vertex="1">
          <mxGeometry height="420" width="420" x="480" y="200" as="geometry" />
        </mxCell>
        <mxCell id="p8-rtj-i" parent="p8-rtj" style="shape=mxgraph.aws4.resourceIcon;resIcon=mxgraph.aws4.bedrock_agentcore;fillColor=#01A88D;strokeColor=#ffffff;aspect=fixed;html=1;verticalLabelPosition=bottom;verticalAlign=top;align=center;fontSize=10;fontFamily=Helvetica;" value="customJWT" vertex="1">
          <mxGeometry height="48" width="48" x="186" y="35" as="geometry" />
        </mxCell>
        <mxCell id="p8-sse-ep" parent="p8-rtj" style="rounded=1;fillColor=#C8E6C9;strokeColor=#2E7D32;strokeWidth=2;html=1;align=left;verticalAlign=top;fontSize=11;fontStyle=1;fontColor=#2E7D32;fontFamily=Helvetica;spacing=8;" value="/invocations SSE (1b)&#xa;&lt;span style=&#39;font-weight:normal;font-size:10px&#39;&gt;Accept: text/event-stream&lt;br&gt;existing Phase 1b path&lt;br&gt;server→client only&lt;br&gt;17 AG-UI events&lt;/span&gt;" vertex="1">
          <mxGeometry height="100" width="380" x="20" y="120" as="geometry" />
        </mxCell>
        <mxCell id="p8-ws-ep" parent="p8-rtj" style="rounded=1;fillColor=light-dark(#FFFFFF,#2a2a2a);strokeColor=#ED7100;strokeDasharray=8 4;strokeWidth=3;html=1;align=left;verticalAlign=top;fontSize=11;fontStyle=1;fontColor=#BF5700;fontFamily=Helvetica;spacing=8;" value="/ws (WebSocket, NEW 1c+)&#xa;&lt;span style=&#39;font-weight:normal;font-size:10px&#39;&gt;bidirectional frames&lt;br&gt;server→client: same 17 AG-UI events&lt;br&gt;client→server: USER_NUDGE, TOOL_USE_APPROVAL_RESPONSE, CANCEL&lt;/span&gt;" vertex="1">
          <mxGeometry height="150" width="380" x="20" y="240" as="geometry" />
        </mxCell>
        <mxCell id="p8-agent" parent="p8-cloud" style="rounded=1;fillColor=light-dark(#F5F5F5,#2a2a2a);strokeColor=#01A88D;strokeWidth=2;strokeDasharray=8 4;html=1;verticalAlign=top;fontStyle=1;fontSize=12;fontFamily=Helvetica;fontColor=#01A88D;container=1;collapsible=0;spacingLeft=10;spacingTop=6;" value="Agent container (1c+)" vertex="1">
          <mxGeometry height="500" width="500" x="950" y="200" as="geometry" />
        </mxCell>
        <mxCell id="p8-1b-kept" parent="p8-agent" style="rounded=1;fillColor=#E0F2F1;strokeColor=#01A88D;html=1;align=left;verticalAlign=top;fontSize=10;fontStyle=1;fontColor=#01A88D;fontFamily=Helvetica;spacing=8;" value="&lt;b&gt;Everything from Phase 1b kept:&lt;/b&gt;&lt;br&gt;&lt;span style=&#39;font-weight:normal&#39;&gt;server.py, pipeline.py, runner.py&lt;br&gt;ProgressWriter → DDB&lt;br&gt;SSEAdapter → asyncio.Queue&lt;br&gt;/invocations SSE (Accept: text/event-stream)&lt;/span&gt;" vertex="1">
          <mxGeometry height="110" width="470" x="15" y="40" as="geometry" />
        </mxCell>
        <mxCell id="p8-new-inbox" parent="p8-agent" style="rounded=1;fillColor=light-dark(#FFFFFF,#2a2a2a);strokeColor=#ED7100;strokeDasharray=8 4;strokeWidth=2;html=1;align=left;verticalAlign=top;fontSize=11;fontStyle=1;fontColor=#BF5700;fontFamily=Helvetica;spacing=8;" value="&lt;b&gt;NudgeInbox (NEW, 1c+)&lt;/b&gt;&lt;br&gt;&lt;span style=&#39;font-weight:normal;font-size:10px&#39;&gt;per-session asyncio.Queue of inbound frames&lt;br&gt;WebSocket handler decodes client frames, validates via Cedar policy, pushes to inbox&lt;br&gt;runner.py polls inbox between turns; injects USER_NUDGE into next Claude SDK prompt&lt;/span&gt;" vertex="1">
          <mxGeometry height="140" width="470" x="15" y="170" as="geometry" />
        </mxCell>
        <mxCell id="p8-new-cedar" parent="p8-agent" style="rounded=1;fillColor=light-dark(#FFFFFF,#2a2a2a);strokeColor=#ED7100;strokeDasharray=8 4;strokeWidth=2;html=1;align=left;verticalAlign=top;fontSize=11;fontStyle=1;fontColor=#BF5700;fontFamily=Helvetica;spacing=8;" value="&lt;b&gt;Cedar HITL policy engine (NEW, 1c+)&lt;/b&gt;&lt;br&gt;&lt;span style=&#39;font-weight:normal;font-size:10px&#39;&gt;decides whether TOOL_USE requires user approval&lt;br&gt;if yes → server emits TOOL_USE_APPROVAL_REQUEST via WS&lt;br&gt;→ runner.py blocks turn until response arrives or times out&lt;br&gt;design §9.3 rev 4 (pending finalization)&lt;/span&gt;" vertex="1">
          <mxGeometry height="150" width="470" x="15" y="330" as="geometry" />
        </mxCell>
        <mxCell id="p8-user" parent="p8-1" style="rounded=1;fillColor=light-dark(#FFFFFF,#2a2a2a);strokeColor=#ED7100;strokeWidth=2;strokeDasharray=8 4;html=1;verticalAlign=top;fontStyle=1;fontSize=12;fontFamily=Helvetica;fontColor=#BF5700;container=1;collapsible=0;" value="bgagent CLI (1c+)" vertex="1">
          <mxGeometry height="180" width="180" x="60" y="480" as="geometry" />
