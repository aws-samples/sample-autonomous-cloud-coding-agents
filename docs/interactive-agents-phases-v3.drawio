        <mxCell id="p2-rti-i" parent="p2-rti" style="shape=mxgraph.aws4.resourceIcon;resIcon=mxgraph.aws4.bedrock_agentcore;fillColor=#01A88D;strokeColor=#ffffff;aspect=fixed;html=1;verticalLabelPosition=bottom;verticalAlign=top;align=center;fontSize=10;fontFamily=Helvetica;" value="&lt;div&gt;AgentCore Runtime&lt;/div&gt;authType = IAM" vertex="1">
