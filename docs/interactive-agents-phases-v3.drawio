        <mxCell id="p3-fanout" parent="p3-1" style="rounded=1;fillColor=#F5E6F7;strokeColor=#C925D1;strokeWidth=3;html=1;verticalAlign=top;fontStyle=1;fontSize=16;fontFamily=Helvetica;fontColor=#C925D1;container=1;collapsible=0;spacingLeft=10;spacingTop=6;" value="FAN-OUT PLANE (DDB Stream, async push) — NEW in Phase 1b" vertex="1">
          <mxGeometry height="240" width="1800" x="40" y="680" as="geometry" />
        </mxCell>
        <mxCell id="p3-fanout-d" parent="p3-fanout" style="text;html=1;fontSize=12;fontFamily=Helvetica;fontColor=#C925D1;align=left;verticalAlign=top;spacing=8;" value="&lt;b&gt;Transport:&lt;/b&gt; TaskEventsTable DDB Stream → Lambda filter/batch/rate-limit → destination API.&amp;nbsp;&lt;div&gt;&lt;b&gt;Targets:&lt;/b&gt; Slack chat.postMessage, GitHub PR comment, SES, SNS. &lt;b&gt;Pattern:&lt;/b&gt; asynchronous PUSH.&amp;nbsp;&lt;/div&gt;&lt;div&gt;&lt;b&gt;Why not SSE?&lt;/b&gt; Non-interactive consumers cannot hold open long-lived streams; Slack bots must ACK in 3s.&amp;nbsp;&lt;/div&gt;&lt;div&gt;&lt;b&gt;Filter:&lt;/b&gt; milestone+error events only; verbose TEXT_MESSAGE_CONTENT suppressed.&lt;/div&gt;" vertex="1">
          <mxGeometry height="80" width="1760" x="20" y="40" as="geometry" />
        </mxCell>
