        <mxCell id="p3-bidi-el" connectable="0" parent="p3-bidi-e" style="edgeLabel;html=1;fontSize=11;fontFamily=Helvetica;fontColor=#BF5700;fontStyle=1;" value="nudges ⇄ events" vertex="1">
          <mxGeometry relative="1" as="geometry" />
