{
  "compilerOptions": {
    "rootDir": "..",
    "outDir": "../../lib",
    "target": "ES2022",
    "module": "Node16",
    "moduleResolution": "Node16",
    "jsx": "react-jsx",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "declaration": true,
    "inlineSourceMap": true,
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "types": ["node"]
  },
  "include": [
    "./**/*.ts",
    "./**/*.tsx",
    "../types.ts"
  ],
  "exclude": []
}
