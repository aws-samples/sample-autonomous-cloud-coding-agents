{
  "name": "rule11-comment-outcome-s3-only-target",
  "description": "primary outcome 'comment' but the only deliver_artifact step targets s3 (produces an artifact, never posts a comment); kind-presence alone is insufficient.",
  "workflow": {
    "id": "knowledge/note-v1",
    "version": "1.0.0",
    "domain": "knowledge",
    "description": "Deliver to s3 but claim a comment terminal outcome.",
    "read_only": false,
    "prompt": {
      "template": "registry://prompt/web-research-workflow"
    },
    "hydration": {
      "sources": [
        "task_description"
      ]
    },
    "agent_config": {
      "tier": "elevated",
      "allowed_tools": [
        "Read",
        "WebFetch"
      ],
      "mcp_servers": [
        "registry://mcp/web-search-v1"
      ],
      "cedar_policy_modules": [
        "builtin/hard_deny",
        "builtin/soft_deny"
      ]
    },
    "repo_config": {
      "discover": false
    },
    "required_inputs": {
      "all_of": [
        "task_description"
      ]
    },
    "steps": [
      {
        "kind": "hydrate_context"
      },
      {
        "kind": "run_agent"
      },
      {
        "kind": "deliver_artifact",
        "target": "s3"
      }
    ],
    "terminal_outcomes": {
      "primary": "comment"
    },
    "limits": {
      "max_turns": 25,
      "max_budget_usd": 5
    },
    "promotion_gate": {
      "requires": [
        "eval:web-research-quality"
      ]
    },
    "status": "production"
  },
  "expected": {
    "valid": false,
    "violations": [
      "rule-11"
    ]
  }
}
